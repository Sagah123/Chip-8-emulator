{
  "version": 3,
  "configurePresets": [
    {
      "name": "windows-default",
      "displayName": "Windows MinGW (Default)",
      "description": "MinGW",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "ninja-default",
      "displayName": "Ninja Multi-Config",
      "description": "Alternative way via Ninja",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build"
    }
  ]
}